# Copy this file to .env and fill in real values before running locally.
# docker-compose reads .env automatically.

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=flight_planning

# Constructed from the above — used by Flask/SQLAlchemy inside the container
DATABASE_URL=postgresql://user:password@db:5432/flight_planning

# Application
PORT=8004
FLASK_DEBUG=false
